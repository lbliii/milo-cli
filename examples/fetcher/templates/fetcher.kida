{% from "components/_defs.kida" import header, status_line, kv_pair, key_hints %}
{{ header("URL Fetcher") }}
{{ hr() }}

  {{ "URL:" | bold }} {{ state.url }}

{% match state.status %}
{% case "idle" %}
  Press {{ "Enter" | green }} to fetch.
{% case "loading" %}
  {{ status_line("warning", "Fetching..." | bold | yellow) }}
{% case "done" %}
  {{ status_line("success", "Done") }}
  {{ kv_pair("Status", state.status_code) }}
  {{ kv_pair("Size", state.content_length | filesizeformat) }}
{% case "error" %}
  {{ status_line("error", "Error") }}
  {{ state.error_message | dim }}
{% endmatch %}

{{ hr() }}
{{ key_hints([{"key": "enter", "action": "fetch"}, {"key": "esc", "action": "quit"}]) }}
