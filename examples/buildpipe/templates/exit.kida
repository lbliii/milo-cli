{% from "components/_defs.kida" import format_time -%}
{% match state.status -%}
{% case "completed" -%}
{{ "✓" | green }} Pipeline {{ state.name | bold }} completed in {{ format_time(state.elapsed) }}.
{% case "failed" -%}
{{ "✗" | red }} Pipeline {{ state.name | bold }} failed at {{ state.current_phase | bold }}.
{% case _ -%}
Pipeline {{ state.name | bold }} exited with status {{ state.status | bold }}.
{% endmatch -%}
